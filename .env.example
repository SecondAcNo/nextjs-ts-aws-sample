POSTGRES_DB=portfolio_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portfolio_db?schema=public"
AUTH_MODE=local

AWS_REGION=ap-northeast-1
COGNITO_USER_POOL_ID=ap-northeast-1_xxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

COGNITO_TEST_ADMIN_EMAIL=your-email@example.com
COGNITO_TEST_ADMIN_SUB=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

NEXT_PUBLIC_AUTH_MODE=local
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_COGNITO_DOMAIN=https://your-cognito-domain.auth.ap-northeast-1.amazoncognito.com
NEXT_PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000/
NEXT_PUBLIC_COGNITO_LOGOUT_URI=http://localhost:3000/

# CDK deploy parameters. Do not put real production secrets in this file.
CDK_DATABASE_URL="postgresql://user:password@host:5432/database?schema=public&sslmode=no-verify"
CDK_COGNITO_DOMAIN_PREFIX=workops-portfolio-yourname
